#!/bin/sh
# Pre-commit hook: 检查所有暂存的 Python 文件是否有 UTF-8 编码问题
# 安装方法: git config core.hooksPath .githooks

echo "Checking UTF-8 encoding..."

ERRORS=0
for file in $(git diff --cached --name-only --diff-filter=ACM | grep '\.py$'); do
    if [ -f "$file" ]; then
        # 检查 UTF-8 编码
        python -c "
import sys
try:
    open('$file', 'r', encoding='utf-8').read()
except UnicodeDecodeError as e:
    print(f'ENCODING ERROR: $file - {e}')
    sys.exit(1)
" 2>/dev/null
        if [ $? -ne 0 ]; then
            ERRORS=$((ERRORS + 1))
            continue
        fi

        # 检查语法
        python -c "
import py_compile, sys
try:
    py_compile.compile('$file', doraise=True)
except py_compile.PyCompileError as e:
    print(f'SYNTAX ERROR: $file - {e.msg.splitlines()[0]}')
    sys.exit(1)
" 2>/dev/null
        if [ $? -ne 0 ]; then
            ERRORS=$((ERRORS + 1))
        fi
    fi
done

if [ $ERRORS -gt 0 ]; then
    echo ""
    echo "❌ 发现 $ERRORS 个文件有编码或语法错误，提交已阻止"
    echo "请修复后重新 git add && git commit"
    exit 1
fi

echo "✅ 编码检查通过"
exit 0
