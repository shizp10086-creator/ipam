# 数据库配置
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=ipam
MYSQL_PASSWORD=ipam_password
MYSQL_DATABASE=ipam_db

# Ping 代理配置
USE_PING_PROXY=true
PING_PROXY_URL=http://host.docker.internal:8001

# Ping 源 IP 配置（可选）
# 指定从哪个网络接口发送 ping 请求
# 例如：PING_SOURCE_IP=172.18.201.1
# 如果不设置，使用系统默认路由
PING_SOURCE_IP=

# JWT 配置
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
