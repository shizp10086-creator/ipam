# Project Configuration
PROJECT_NAME=IPAM System
VERSION=1.0.0

# Database Configuration
# 本地开发模式：MYSQL_HOST=localhost
# Docker Compose 模式：MYSQL_HOST=mysql
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=ipam
MYSQL_PASSWORD=ipam_password
MYSQL_DATABASE=ipam_db

# JWT Configuration (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration (comma-separated list)
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Logging Configuration
LOG_LEVEL=INFO

# Default Admin User (created on first startup)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@ipam.local
DEFAULT_ADMIN_FULLNAME=System Administrator

# Ping 配置
# 是否使用 Ping 代理服务（推荐在容器环境中使用）
USE_PING_PROXY=true
# Ping 代理服务 URL（使用 host.docker.internal 访问宿主机服务）
PING_PROXY_URL=http://host.docker.internal:8001
# Ping 源 IP 地址（可选，用于指定从哪个网络接口发送 ping）
# 例如：PING_SOURCE_IP=172.18.201.1
# 如果不设置，使用系统默认路由
PING_SOURCE_IP=
